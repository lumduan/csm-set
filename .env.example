# TradingView authentication (optional — lifts the 5,000-bar anonymous cap)
# Provide TradingView session cookies as a JSON object on a single line.
# Required key: sessionid. Recommended companions: sessionid_sign, device_t, tv_ecuid.
# Extract via your browser's devtools → Application → Cookies → tradingview.com.
# TVKIT_AUTH_TOKEN={"sessionid":"...","sessionid_sign":"...","device_t":"...","tv_ecuid":"..."}

# Application
CSM_ENV=development
CSM_DATA_DIR=./data
CSM_LOG_LEVEL=INFO

# Public mode — set true to disable all data fetch/write operations
# Anyone cloning the repo should leave this as true (default in Docker)
CSM_PUBLIC_MODE=false

# Results directory — pre-computed outputs committed to git
CSM_RESULTS_DIR=./results

# API
CSM_API_HOST=0.0.0.0
CSM_API_PORT=8000

# API key for private-mode protected endpoints (X-API-Key header).
# Leave unset for local development — a startup WARNING reminds you auth is disabled.
# Set to a strong random secret for any deployment beyond loopback.
# CSM_API_KEY=changeme-strong-random-string

# UI
CSM_UI_PORT=8080

# Scheduler (Asia/Bangkok timezone, owner-only — ignored when public_mode=true)
CSM_REFRESH_CRON=0 18 * * 1-5

# quant-infra-db connections (required when CSM_DB_WRITE_ENABLED=true)
# CSM_DB_CSM_SET_DSN=postgresql://postgres:<pass>@quant-postgres:5432/db_csm_set
# CSM_DB_GATEWAY_DSN=postgresql://postgres:<pass>@quant-postgres:5432/db_gateway
# CSM_MONGO_URI=mongodb://quant-mongo:27017/
CSM_DB_WRITE_ENABLED=false
