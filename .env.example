# TradingView authentication (optional — increases historical bar limit)
# Leave unset to run in anonymous mode (5,000 bars per symbol)
TVKIT_BROWSER=chrome
# TVKIT_AUTH_TOKEN=your_token_here

# Application
CSM_ENV=development
CSM_DATA_DIR=./data
CSM_LOG_LEVEL=INFO

# Public mode — set true to disable all data fetch/write operations
# Anyone cloning the repo should leave this as true (default in Docker)
CSM_PUBLIC_MODE=false

# Results directory — pre-computed outputs committed to git
CSM_RESULTS_DIR=./results

# API
CSM_API_HOST=0.0.0.0
CSM_API_PORT=8000

# API key for private-mode protected endpoints (X-API-Key header).
# Leave unset for local development — a startup WARNING reminds you auth is disabled.
# Set to a strong random secret for any deployment beyond loopback.
# CSM_API_KEY=changeme-strong-random-string

# UI
CSM_UI_PORT=8080

# Scheduler (Asia/Bangkok timezone, owner-only — ignored when public_mode=true)
CSM_REFRESH_CRON=0 18 * * 1-5
